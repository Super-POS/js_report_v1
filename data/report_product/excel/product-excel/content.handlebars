<!DOCTYPE html>
<html>
<head>
<meta charset="utf-8">
<style>
  body { font-family: Arial, sans-serif; font-size: 12px; }
  table { border-collapse: collapse; }
  th { background: #2d4a6a; color: #fff; font-weight: bold; padding: 6px 10px; border: 1px solid #1a2f4a; text-align: center; }
  td { padding: 5px 10px; border: 1px solid #999; }
  .right  { text-align: right; }
  .center { text-align: center; }
  .totals { background: #f0f0f0; font-weight: bold; }
  .meta td { border: none; padding: 2px 6px; }
</style>
</head>
<body>
<h2 style="margin:0 0 4px 0;">Product Sales Report / របាយការណ៍លក់តាមផលិតផល</h2>
<table class="meta" style="margin-bottom:10px;">
  <tr><td>Period:</td><td>{{data.startDate}} &nbsp;to&nbsp; {{data.endDate}}</td></tr>
  <tr><td>Printed:</td><td>{{data.currentDate}} {{data.currentTime}}</td></tr>
  <tr><td>Cashier:</td><td>{{data.name}}</td></tr>
</table>
<table>
  <thead>
    <tr>
      <th>No.</th>
      <th>Product</th>
      <th>Type</th>
      <th>Unit Price</th>
      <th>Qty</th>
      <th>Total</th>
    </tr>
  </thead>
  <tbody>
    {{#each data.receipts}}
    <tr>
      <td class="center">{{inc @index}}</td>
      <td>{{name}}</td>
      <td>{{#if type}}{{type.name}}{{/if}}</td>
      <td class="right">{{money unit_price}}</td>
      <td class="center">{{total_qty}}</td>
      <td class="right">{{money total_sales}}</td>
    </tr>
    {{/each}}
    <tr class="totals">
      <td colspan="4" class="right">Total</td>
      <td class="center">{{data.SumTotalSale}}</td>
      <td class="right">{{money data.SumTotalPrice}}</td>
    </tr>
  </tbody>
</table>
</body>
</html>
